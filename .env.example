# Runtime/context budget
TOKEN_BUDGET=2560000
CONTEXT_LIMIT_TOKENS=256000
MAX_STEPS=88
COMPACT_TRIGGER_RATIO=0.85
WARNING_TRIGGER_RATIO=0.80
BLOCKING_TRIGGER_RATIO=0.98
DEFAULT_MAX_OUTPUT_TOKENS=8000
ESCALATED_MAX_OUTPUT_TOKENS=64000
COMPACT_MAX_OUTPUT_TOKENS=20000
