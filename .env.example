OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
Q_CODE_MODEL_PROVIDER=auto
Q_CODE_THINKING_TYPE=
Q_CODE_REASONING_EFFORT=

# Runtime/context budget
CONTEXT_LIMIT_TOKENS=256000
COMPACT_TRIGGER_RATIO=0.85
WARNING_TRIGGER_RATIO=0.80
BLOCKING_TRIGGER_RATIO=0.98
DEFAULT_MAX_OUTPUT_TOKENS=8000
ESCALATED_MAX_OUTPUT_TOKENS=64000
COMPACT_MAX_OUTPUT_TOKENS=20000
Q_CODE_MODEL_WAIT_HEARTBEAT_MS=10000
Q_CODE_MODEL_SLOW_REQUEST_WARN_MS=30000
Q_CODE_MODEL_STALLED_REQUEST_WARN_MS=60000
Q_CODE_MODEL_REQUEST_TIMEOUT_MS=0
Q_CODE_SESSION_DIR=.sessions
Q_CODE_HOME=
Q_CODE_PROJECT_ROOT=
Q_CODE_DEBUG=
Q_CODE_THEME=auto
Q_CODE_AUDIT_ENABLED=true
Q_CODE_AUDIT_DIR=
Q_CODE_AUDIT_RETENTION_DAYS=30
Q_CODE_AUDIT_MAX_FILE_BYTES=52428800
Q_CODE_AUDIT_MAX_QUEUE_SIZE=1000
Q_CODE_AUDIT_PII=
Q_CODE_CRASH_GUARD=true

# TUI input history
Q_CODE_HISTORY_DISABLED=false
Q_CODE_HISTORY_SCOPE=both
Q_CODE_HISTORY_REDACT=false
Q_CODE_HISTORY_SEARCH=substring
Q_CODE_HISTORY_MAX_LINES=20000
Q_CODE_HISTORY_MAX_BYTES=5242880
Q_CODE_HISTORY_RUNTIME_LIMIT=2000
Q_CODE_HISTORY_MAX_LINE_BYTES=32768

# Optional Langfuse tracing exporter
Q_CODE_LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
Q_CODE_LANGFUSE_RECORD_IO=false
Q_CODE_LANGFUSE_SAMPLE_RATE=1
Q_CODE_LANGFUSE_ENVIRONMENT=
Q_CODE_LANGFUSE_RELEASE=
Q_CODE_LANGFUSE_FLUSH_AT=20
Q_CODE_LANGFUSE_FLUSH_INTERVAL_SECONDS=5
Q_CODE_LANGFUSE_TIMEOUT_SECONDS=5

# Optional deterministic agent evals
# Local artifacts are written to .q-code/evals/runs/<run-id>/.
# cli-subprocess evals run in isolated fixture workspaces under the run dir.
# Use --tag/--mode filters and --max-cases/--max-duration-ms/--max-cost-usd guards for CI runs.
# Case expectations can score final answer quality, tool trajectory, budgets, side effects, and safety/policy leaks.
# Use Q_CODE_LANGFUSE_ENABLED=true to also export eval summaries to Langfuse.
# Use q-code eval run --langfuse-datasets to also sync Langfuse dataset run items and scores.
# real-agent and LLM judge evals require explicit CLI opt-in flags and are never enabled by default.
Q_CODE_EVAL_JUDGE_BASE_URL=
Q_CODE_EVAL_JUDGE_API_KEY=
Q_CODE_EVAL_JUDGE_MODEL=

Q_CODE_MENTION_ALLOW_ABS=false
Q_CODE_FILE_INDEX_IGNORE=
Q_CODE_SHELL_TIMEOUT_MS=60000
Q_CODE_SHELL_TIMEOUT_MAX_MS=1800000
Q_CODE_SHELL_MAX_BUFFER=4194304
Q_CODE_SHELL_ALLOW_ABS_CWD=false
Q_CODE_SHELL_KILL_BG_ON_EXIT=false
MCP_CONNECT_TIMEOUT_MS=30000

Q_CODE_TEAMS=

# Team AI infra / enterprise config sync
Q_CODE_INFRA_ENABLED=false
Q_CODE_INFRA_BASE_URL=
Q_CODE_INFRA_TOKEN=
Q_CODE_INFRA_CLIENT_ID=
Q_CODE_INFRA_CACHE_DIR=
Q_CODE_INFRA_SYNC=true
Q_CODE_INFRA_TIMEOUT_MS=5000
Q_CODE_INFRA_USER_ID=
Q_CODE_INFRA_USER_NAME=
Q_CODE_INFRA_USER_GROUPS=
Q_CODE_INFRA_UPLOAD_SOURCE=false

# GitLab Wiki repository knowledge base
Q_CODE_GITLAB_KB_ENABLED=
Q_CODE_GITLAB_URL=
Q_CODE_GITLAB_TOKEN=
Q_CODE_GITLAB_PROJECT_ID=
Q_CODE_GITLAB_KB_PREFIX=q-code-kb
Q_CODE_GITLAB_KB_TIMEOUT_MS=10000
# Summary 专用模型配置
SUMMARY_BASE_URL=
SUMMARY_API_KEY=
SUMMARY_MODEL=deepseek-v4-flash
TAVILY_API_KEY=
SERPER_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
